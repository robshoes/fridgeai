# Copy to .env and fill in real values. Never commit .env.
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time —
# only put values here that are safe to ship to end users (Supabase access
# here is protected by Row Level Security, not by keeping the anon key secret).
# The OpenAI key is NEVER put here: it lives only in Supabase Edge Function secrets.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# AdMob — leave empty to fall back to Google's official test IDs (safe
# defaults, see app.config.ts / src/features/ads/adUnitIds.ts). Fill in
# once a real AdMob account/app exists.
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_UNIT_ID_IOS=
