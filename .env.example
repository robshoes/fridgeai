# Copy to .env and fill in real values. Never commit .env.
# EXPO_PUBLIC_* vars are inlined into the client bundle at build time —
# only put values here that are safe to ship to end users (Supabase access
# here is protected by Row Level Security, not by keeping the anon key secret).
# The OpenAI key is NEVER put here: it lives only in Supabase Edge Function secrets.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — leave both empty to disable analytics entirely (no-op, see
# src/services/analytics.ts). Host depends on which cloud region the
# PostHog project was created in: https://us.i.posthog.com or
# https://eu.i.posthog.com (or your self-hosted URL).
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
